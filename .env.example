# Copy this file to .env and fill in the values.
# At minimum NVIDIA_API_KEY is required for Phase 1.

# === LLM inference providers ===

# NVIDIA API Catalog - https://build.nvidia.com
# Primary inference provider. Format: nvapi-...
NVIDIA_API_KEY=

# Groq Cloud - https://console.groq.com/keys
# Fast inference for high-throughput eval. Format: gsk_...
GROQ_API_KEY=

# Together AI - https://api.together.ai/settings/api-keys
# Broad model catalog, fallback when other providers are rate-limited.
TOGETHER_API_KEY=

# Hugging Face - https://huggingface.co/settings/tokens
# Used for dataset upload (Phase 3) and HF Inference Providers.
# Role: Read is fine for Phase 0-2; upgrade to Write for Phase 3 dataset upload.
HF_TOKEN=

# === MCP server credentials (Phase 2) ===

# GitHub MCP server - https://github.com/settings/tokens
# Personal access token (classic or fine-grained). Read-only scopes are
# enough for our read-oriented github tasks. Required only if running the
# github server.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Postgres MCP server connection string. Defaults to the local Docker
# container created by backend/scripts/setup_postgres.ps1. Override only if
# you point at a different instance.
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/mcpbench

# === Optional ===

# Weights & Biases - https://wandb.ai/authorize
# Experiment tracking for runs. Free tier is enough.
WANDB_API_KEY=
