  {
    "id": "fs_014_delete_by_content",
    "description": "Find and delete the file with specific content",
    "prompt": "Three files are in your working directory. Exactly one of them contains the text 'DELETE ME'. Find that file and delete it. Leave the others untouched.",
    "servers": ["filesystem"],
    "setup": [
      {"kind": "write_file", "params": {"path": "keep1.txt", "content": "important data"}},
      {"kind": "write_file", "params": {"path": "target.txt", "content": "DELETE ME"}},
      {"kind": "write_file", "params": {"path": "keep2.txt", "content": "also keep this"}}
    ],
    "check": {"kind": "all_of", "params": {"checks": [
      {"kind": "file_not_exists", "params": {"path": "target.txt"}},
      {"kind": "file_exists", "params": {"path": "keep1.txt"}},
      {"kind": "file_exists", "params": {"path": "keep2.txt"}}
    ]}},
    "tags": ["multi-step", "write"],
    "difficulty": "hard",
    "skill": "composition"
  }
